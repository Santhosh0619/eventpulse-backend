# App
APP_NAME=EventPulse
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:8081"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eventpulse
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP — MailHog for dev, Gmail SMTP for prod)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
FROM_EMAIL=noreply@eventpulse.com

# Stripe (free test mode — no charges until you go live)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Local File Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
SERVE_UPLOADS_URL=/uploads

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_JSON={"type":"service_account"}

# Frontend URLs (for email links)
WEB_APP_URL=http://localhost:5173

# Google Gemini (AI features — free tier: gemini-2.0-flash, 15 RPM)
# Leave empty to disable AI features (they fall back to non-AI behaviour).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
